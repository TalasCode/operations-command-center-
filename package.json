{
  "name": "operations-command-center",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "prisma:generate": "prisma generate",
    "db:push": "python scripts/init_db.py",
    "db:reset": "python scripts/reset_db.py && python scripts/init_db.py",
    "test": "cross-env DATABASE_URL=file:./test.db python scripts/init_db.py && cross-env DATABASE_URL=file:./test.db vitest run",
    "test:watch": "cross-env DATABASE_URL=file:./test.db python scripts/init_db.py && cross-env DATABASE_URL=file:./test.db vitest"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "cross-env": "^7.0.3",
    "prisma": "^6.8.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
