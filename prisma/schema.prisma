generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id             String            @id @default(cuid())
  sourceEventId  String            @unique @map("source_event_id")
  source         String
  eventType      String            @map("event_type")
  detectedStream String            @default("unknown") @map("detected_stream")
  payload        Json
  status         String
  reviewRequired Boolean           @default(false) @map("review_required")
  lastError      String?           @map("last_error")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")
  actions        Action[]
  reviewItems    ReviewQueueItem[]
  auditLogs      AuditLog[]

  @@map("events")
}

model Action {
  id        String   @id @default(cuid())
  eventId    String   @map("event_id")
  type      String
  service   String
  payload   Json
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("actions")
}

model ReviewQueueItem {
  id              String   @id @default(cuid())
  eventId         String   @map("event_id")
  reason          String
  status          String
  resolutionNotes String?  @map("resolution_notes")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  resolvedAt      DateTime? @map("resolved_at")
  event           Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("review_queue_items")
}

model AuditLog {
  id        String   @id @default(cuid())
  eventId    String   @map("event_id")
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
